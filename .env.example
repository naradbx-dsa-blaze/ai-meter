# Databricks Workspace
DATABRICKS_HOST=https://e2-demo-field-eng.cloud.databricks.com
DATABRICKS_TOKEN=your_pat_token_here
DATABRICKS_SQL_WAREHOUSE_ID=e9b34f7a2e4b0561   # Serverless Starter Warehouse (required for UC DDL)

# Unity Catalog
DATABRICKS_CATALOG=nara_demo
DATABRICKS_SCHEMA=default

# Model Serving Endpoint to proxy
FM_ENDPOINT_NAME=databricks-meta-llama-3-1-70b-instruct

# Token Budgets
DEFAULT_DAILY_TOKEN_LIMIT=2000
SOFT_ALERT_THRESHOLD=0.8     # send warning at 80% usage

# Slack (use either webhook or bot token)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_DEFAULT_CHANNEL=#ai-usage-alerts
